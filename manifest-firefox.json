{
  "manifest_version": 2,

  "name": "$(NAME)",
  "description": "__MSG_extensionDescription__",
  "default_locale" : "en",
  "icons": {"128": "./assets/icons/icon128.png"},
  "author": "$(AUTHOR)",
  "homepage_url": "$(HOMEPAGE_URL)",
  "version": "$(VERSION)",

  "browser_specific_settings": {
    "gecko": {
      "id": "{ebd90edc-897a-45bd-ba8b-7f9240a3a7cc}",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": [
    "*://kodik-api.com/*",
    "*://raw.githubusercontent.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://shikimori.me/*", "*://shikimori.one/*", "*://shikimori.io/*", "*://shiki.one/*", "*://kodik.info/*"],
      "all_frames": true,
      "js": ["Shikiplayer.js"],
      "run_at": "document_end"
    }
  ]
}
